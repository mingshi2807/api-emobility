{
  "name": "vedecom-emobility-apis",
  "version": "0.1.0",
  "private": true,
  "description": "Redocly Realm documentation workspace for VEDECOM eMobility APIs.",
  "dependencies": {
    "@redocly/cli": "2.31.6",
    "@redocly/realm": "0.133.1"
  },
  "scripts": {
    "lint": "redocly lint",
    "lint:dist": "redocly lint --config redocly.dist.yaml",
    "bundle": "redocly bundle",
    "preview": "redocly preview --product=realm --port=4000",
    "preview:realm": "redocly preview --product=realm --port=4000",
    "preview:dist": "npm run bundle && sh scripts/preview-dist.sh",
    "preview:dist:no-bundle": "sh scripts/preview-dist.sh"
  }
}
